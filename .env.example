# Codex Autorunner (CAR) user-authored environment variables
# Copy to .env only for secrets or private identifiers.
# Put non-secret behavior and runtime settings in codex-autorunner.yml,
# codex-autorunner.override.yml, or .codex-autorunner/config.yml.
#
# Precedence:
# built-in defaults < codex-autorunner.yml < override file
# < .codex-autorunner/config.yml < env vars
#
# See docs/ops/env-and-defaults.md for the full contract.

# =============================================================================
# Core / Hub
# =============================================================================

# Hub root directory (set by CLI --hub flag; usually not needed in .env).
# CAR_HUB_ROOT=

# Override the global CAR state root for shared caches and locks (not Codex CLI credentials).
# Default: ~/.codex-autorunner
# CAR_GLOBAL_STATE_ROOT=

# Codex CLI data directory (sessions, auth.json; also the default base for usage caches when
# usage.global_cache_root is null in YAML). Not interchangeable with CAR_GLOBAL_STATE_ROOT.
# Default: ~/.codex
# CODEX_HOME=

# Dev-only: include the source repo itself in the hub manifest when the hub root
# is the codex-autorunner source tree.
# CAR_DEV_INCLUDE_ROOT_REPO=

# Override the command used to launch the app-server subprocess.
# CAR_CODEX_APP_SERVER_COMMAND=

# Override the OpenCode binary command path for Telegram sessions.
# CAR_OPENCODE_COMMAND=

# Explicit path to the Codex CLI binary (protocol schema generation).
# CODEX_BIN=

# Explicit path to the OpenCode binary (protocol schema generation).
# OPENCODE_BIN=

# =============================================================================
# Telegram bot
# =============================================================================

# Telegram Bot API token.
# CAR_TELEGRAM_BOT_TOKEN=

# Telegram Chat ID for the target chat.
# CAR_TELEGRAM_CHAT_ID=

# Telegram thread/topic ID within a forum chat (optional).
# CAR_TELEGRAM_THREAD_ID=

# =============================================================================
# Discord bot / notifications
# =============================================================================

# Discord Bot Token.
# CAR_DISCORD_BOT_TOKEN=

# Discord Application ID.
# CAR_DISCORD_APP_ID=

# Discord webhook URL for notifications.
# CAR_DISCORD_WEBHOOK_URL=

# =============================================================================
# OpenCode server credentials
# =============================================================================

# Username for OpenCode server HTTP Basic auth.
# OPENCODE_SERVER_USERNAME=

# Password for OpenCode server HTTP Basic auth.
# OPENCODE_SERVER_PASSWORD=

# =============================================================================
# API keys
# =============================================================================

# OpenAI API key used by remote Whisper transcription and Docker passthrough.
# OPENAI_API_KEY=

# =============================================================================
# Notifications
# =============================================================================

# Notification delivery timeout (seconds). Also set via config notifications.timeout_seconds.
# Default: 5.0

# =============================================================================
# Editor selection
# =============================================================================

# Make fast-test budget violations fatal instead of report-only.
# Default: 0
# CODEX_FAST_TEST_ENFORCE_BUDGET=0

# Maximum allowed duration (seconds) for individual fast tests.
# Default: 0.2
# CODEX_FAST_TEST_MAX_DURATION_SECONDS=0.2

# Maximum number of slow-test violations to report.
# Default: 20
# CODEX_FAST_TEST_REPORT_LIMIT=20

# Verify collected test node IDs match the JUnit report.
# Default: 0
# CODEX_FAST_TEST_VERIFY_NODEIDS=0

# Enable dead-code checks during local development (normally only in CI).
# Default: 0
# CODEX_LOCAL_CHECK_INCLUDE_DEADCODE=0

# =============================================================================
# Editor selection
# =============================================================================

# Editor precedence for `car edit`: VISUAL > EDITOR > ui.editor config > vi.
# VISUAL=
# EDITOR=
