# Codex Autorunner (CAR) user-authored environment variables
# Copy to .env only for secrets or private identifiers.
# Put non-secret behavior and runtime settings in codex-autorunner.yml,
# codex-autorunner.override.yml, or .codex-autorunner/config.yml.
#
# Precedence:
# built-in defaults < codex-autorunner.yml < override file
# < .codex-autorunner/config.yml < env vars
#
# See docs/ops/env-and-defaults.md for the full contract.

# =============================================================================
# Core / Hub
# =============================================================================

# Hub root directory (set by CLI --hub flag; usually not needed in .env).
# CAR_HUB_ROOT=

# Override the global CAR state root for shared caches and locks (not Codex CLI credentials).
# Default: ~/.codex-autorunner
# CAR_GLOBAL_STATE_ROOT=

# Codex CLI data directory (sessions, auth.json). Not interchangeable with CAR_GLOBAL_STATE_ROOT.
# Default: ~/.codex
# CODEX_HOME=

# Dev-only: include the source repo itself in the hub manifest when the hub root
# is the codex-autorunner source tree.
# CAR_DEV_INCLUDE_ROOT_REPO=

# Skip ./scripts/check.sh during system updates.
# CODEX_AUTORUNNER_SKIP_UPDATE_CHECKS=1

# =============================================================================
# Agent binaries
# =============================================================================

# Override the command used to launch the app-server subprocess.
# CAR_APP_SERVER_COMMAND=

# Legacy per-Telegram override for the app-server command (prefer CAR_APP_SERVER_COMMAND).
# CAR_TELEGRAM_APP_SERVER_COMMAND=

# Override the OpenCode binary command path for Telegram sessions.
# CAR_OPENCODE_COMMAND=

# Explicit path to the Codex CLI binary (protocol schema generation).
# CODEX_BIN=

# Explicit path to the OpenCode binary (protocol schema generation).
# OPENCODE_BIN=

# =============================================================================
# Telegram bot
# =============================================================================

# Telegram Bot API token.
# CAR_TELEGRAM_BOT_TOKEN=

# Telegram Chat ID for the target chat.
# CAR_TELEGRAM_CHAT_ID=

# Telegram thread/topic ID within a forum chat (optional).
# CAR_TELEGRAM_THREAD_ID=

# =============================================================================
# Discord bot / notifications
# =============================================================================

# Discord Bot Token.
# CAR_DISCORD_BOT_TOKEN=

# Discord Application ID.
# CAR_DISCORD_APP_ID=

# Discord webhook URL for notifications.
# CAR_DISCORD_WEBHOOK_URL=

# =============================================================================
# Server / Web UI auth
# =============================================================================

# Example token env var referenced by server.auth_token_env.
# Configure the name in YAML, then set the value here.
# CAR_SERVER_TOKEN=

# =============================================================================
# OpenCode server credentials
# =============================================================================

# Username for OpenCode server HTTP Basic auth.
# OPENCODE_SERVER_USERNAME=

# Password for OpenCode server HTTP Basic auth.
# OPENCODE_SERVER_PASSWORD=

# =============================================================================
# API keys
# =============================================================================

# OpenAI API key used by remote Whisper transcription and Docker passthrough.
# OPENAI_API_KEY=

# =============================================================================
# Voice input
# =============================================================================

# Explicitly enable/disable voice input ("true"/"false" or "1"/"0").
# Auto-enables if OPENAI_API_KEY is present.
# CODEX_AUTORUNNER_VOICE_ENABLED=

# Voice provider: openai_whisper, local_whisper, mlx_whisper.
# Default: local_whisper
# CODEX_AUTORUNNER_VOICE_PROVIDER=

# Voice latency mode: balanced, low.
# Default: balanced
# CODEX_AUTORUNNER_VOICE_LATENCY=

# Voice recording chunk duration in milliseconds.
# Default: 600
# CODEX_AUTORUNNER_VOICE_CHUNK_MS=

# Audio sample rate in Hz.
# Default: 16000
# CODEX_AUTORUNNER_VOICE_SAMPLE_RATE=

# Warn before using a remote voice API ("true"/"false").
# CODEX_AUTORUNNER_VOICE_WARN_REMOTE=

# Push-to-talk maximum recording duration in milliseconds.
# Default: 15000
# CODEX_AUTORUNNER_VOICE_MAX_MS=

# Silence auto-stop duration in milliseconds.
# Default: 1200
# CODEX_AUTORUNNER_VOICE_SILENCE_MS=

# Push-to-talk minimum hold duration in milliseconds.
# Default: 150
# CODEX_AUTORUNNER_VOICE_MIN_HOLD_MS=

# =============================================================================
# Notifications
# =============================================================================

# Notification delivery timeout (seconds). Also set via config notifications.timeout_seconds.
# Default: 5.0

# =============================================================================
# App server
# =============================================================================

# Disable app-server auto-restart (test-only escape hatch).
# CODEX_DISABLE_APP_SERVER_AUTORESTART_FOR_TESTS=

# =============================================================================
# Orchestration / PMA tuning
# =============================================================================

# SQLite busy timeout (milliseconds) for the orchestration database.
# Default: 30000
# CAR_ORCHESTRATION_SQLITE_BUSY_TIMEOUT_MS=

# Grace period (seconds) before auto-dismissing PMA inbox items.
# Default: 3600
# CAR_PMA_INBOX_AUTO_DISMISS_GRACE_SECONDS=

# =============================================================================
# Legacy / Migration
# =============================================================================

# Enable legacy one-way sync mirror from orchestration SQLite to old threads.sqlite3 schema.
# Default: "" (disabled)
# CAR_LEGACY_MIRROR_ENABLED=

# =============================================================================
# ZeroClaw agent runtime
# =============================================================================

# Configuration directory for the ZeroClaw runtime.
# Default: $HOME/.zeroclaw
# ZEROCLAW_CONFIG_DIR=

# Workspace root for the ZeroClaw runtime.
# ZEROCLAW_WORKSPACE=

# =============================================================================
# Test / CI tuning (scripts/check.sh)
# =============================================================================

# Make fast-test budget violations fatal instead of report-only.
# Default: 0
# CODEX_FAST_TEST_ENFORCE_BUDGET=0

# Maximum allowed duration (seconds) for individual fast tests.
# Default: 0.2
# CODEX_FAST_TEST_MAX_DURATION_SECONDS=0.2

# Maximum number of slow-test violations to report.
# Default: 20
# CODEX_FAST_TEST_REPORT_LIMIT=20

# Verify collected test node IDs match the JUnit report.
# Default: 0
# CODEX_FAST_TEST_VERIFY_NODEIDS=0

# Enable dead-code checks during local development (normally only in CI).
# Default: 0
# CODEX_LOCAL_CHECK_INCLUDE_DEADCODE=0

# =============================================================================
# Editor selection
# =============================================================================

# Editor precedence for `car edit`: VISUAL > EDITOR > ui.editor config > vi.
# VISUAL=
# EDITOR=
