{
  "name": "codex-autorunner-ui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "lint:js": "eslint \"src/codex_autorunner/static/generated/**/*.js\" \"src/codex_autorunner/static/vendor/**/*.js\"",
    "lint:ts": "eslint \"src/codex_autorunner/static_src/**/*.ts\"",
    "lint:html": "html-validate \"src/codex_autorunner/static/index.html\"",
    "lint": "eslint \"src/codex_autorunner/static_src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node scripts/version-generated-imports.js && node scripts/add-static-banner.js && node scripts/generate-asset-manifest.mjs",
    "pma:dev": "pnpm --filter @codex-autorunner/pma-hub dev",
    "pma:build": "pnpm --filter @codex-autorunner/pma-hub build",
    "pma:typecheck": "pnpm --filter @codex-autorunner/pma-hub typecheck",
    "pma:lint": "pnpm --filter @codex-autorunner/pma-hub lint",
    "pma:test": "pnpm --filter @codex-autorunner/pma-hub test",
    "test:dom": "node scripts/check_dom_structure.mjs",
    "test:markdown": "node --test tests/js/*.test.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "glob": "^13.0.6",
    "globals": "^17.5.0",
    "html-validate": "^10.13.1",
    "jsdom": "^29.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
