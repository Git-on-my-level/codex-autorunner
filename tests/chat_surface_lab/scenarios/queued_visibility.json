{
  "schema_version": 1,
  "scenario_id": "queued_visibility",
  "description": "A queued submission is visibly acknowledged before recovery resumes the active turn.",
  "surfaces": [
    "discord"
  ],
  "runtime_fixture": {
    "kind": "hermes",
    "scenario": "official_prompt_hang"
  },
  "harness_timeouts": {
    "discord": 25.0
  },
  "approval_mode": "yolo",
  "actions": [
    {
      "kind": "start_message",
      "actor": "user",
      "payload": {
        "text": "cancel me"
      }
    },
    {
      "kind": "wait_for_running_execution",
      "actor": "system",
      "payload": {
        "timeout_seconds": 2.0
      }
    },
    {
      "kind": "submit_active_message",
      "actor": "user",
      "payload": {
        "text": "echo queued after busy",
        "message_id": "m-2"
      }
    },
    {
      "kind": "wait_for_log_event",
      "actor": "system",
      "payload": {
        "event_name": "discord.turn.managed_thread_submission",
        "field": "queued",
        "equals": true,
        "timeout_seconds": 2.0
      }
    },
    {
      "kind": "stop_active_thread",
      "actor": "system",
      "payload": {}
    },
    {
      "kind": "await_active_message",
      "actor": "system",
      "payload": {}
    }
  ],
  "expected_terminal": {
    "status": "interrupted"
  },
  "transcript_invariants": [
    {
      "kind": "log_event_exists",
      "surfaces": [
        "discord"
      ],
      "params": {
        "event_name": "discord.turn.managed_thread_submission",
        "field": "queued",
        "value": true
      }
    }
  ],
  "latency_budgets": [
    {
      "budget_id": "queue_visible",
      "event_name": "chat_ux_timing.discord.turn_delivery",
      "field": "chat_ux_delta_queue_visible_ms",
      "surfaces": [
        "discord"
      ]
    }
  ],
  "contract_links": {
    "regression_ids": [
      "queued_visibility"
    ],
    "latency_budget_ids": [
      "queue_visible"
    ]
  },
  "tags": [
    "ux",
    "queue",
    "hermes",
    "pma"
  ]
}
